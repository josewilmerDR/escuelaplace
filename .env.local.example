# Firebase config (client) — copy to .env.local and fill in with real values.
# These variables are PUBLIC by design (they go to the browser bundle with the
# NEXT_PUBLIC_ prefix). Real security lives in firestore.rules, not in hiding these values.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google Maps (location picker in the page-creation forms).
# Enable "Maps JavaScript API" + "Places API" in the same Google Cloud project and
# create an API key restricted to your domains. PUBLIC (ships to the browser).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# URL of the trackInteraction Cloud Function (view/click counters on business
# profiles). PUBLIC (ships to the browser). Leave empty to disable tracking — the
# contact buttons keep working without it.
# Production form: https://us-central1-<project-id>.cloudfunctions.net/trackInteraction
# Emulators form:  http://127.0.0.1:5001/<project-id>/us-central1/trackInteraction
NEXT_PUBLIC_TRACK_INTERACTION_URL=

# Local development with the Firebase emulators (firebase.json).
# Set to "true" to point the SDK at the local emulators instead of the cloud.
# With this enabled the values above can be dummy (e.g. the demo project below),
# since the emulators do not validate real credentials.
NEXT_PUBLIC_USE_EMULATORS=false
# When using emulators, this project id must match .firebaserc (demo-* needs no real project):
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-escuelaplace
# NEXT_PUBLIC_FIREBASE_API_KEY=demo-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-escuelaplace.firebaseapp.com
