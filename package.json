{
  "name": "escuelaplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore,storage --project demo-escuelaplace --config firebase.emulator-test.json \"vitest run --config vitest.rules.config.ts\"",
    "emulators": "firebase emulators:start --only auth,functions,firestore,storage --import=./.emulator-data --export-on-exit",
    "seed": "node scripts/seed.mjs"
  },
  "dependencies": {
    "@vis.gl/react-google-maps": "^1.8.3",
    "firebase": "^12.14.0",
    "geofire-common": "^6.0.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "firebase-admin": "^12.7.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
