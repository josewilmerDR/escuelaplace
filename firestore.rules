rules_version = '2';

// Security rules for escuelaplace.com
//
// Principles:
// - Public catalog: businesses, schools and categories are READ without authentication (SEO/SSR).
// - The platform NEVER processes payments: there are no transaction collections.
// - Buyers ("person") have NO account: they are not referenced here.
// - Personal donors: any signed-in user (no page needed) may support a school
//   (`supporterType: 'user'` on subscriptions). Their public recognition lives in
//   donorProfiles, is opt-in, and its tier/totals are Cloud-Function-maintained.
// - "Pages" model (Facebook-style): a user account administers one or more pages
//   (businesses and/or schools). Access control lives on the page doc via ownerId/editorIds.
// - Schools are self-administered but verification is admin-gated: owners can never set
//   themselves to 'verified'; only admin writes `verified`/`verificationStatus`.
// - Sensitive data (payment methods) lives in a private subcollection: readable/writable by the
//   school's owner/editors and admin. Public visibility of the payment methods is decided by the
//   data layer based on verificationStatus, not here.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Admin is anchored on the unforgeable custom claim (request.auth.token.admin), set ONLY
    // by the Admin SDK (functions/src/admin.ts grant/revoke + the bootstrap script). The
    // Firestore users/{uid}.role field is a non-authoritative MIRROR for the admin UI; it is
    // honored here as a transitional fallback so admins provisioned before the custom-claim
    // migration aren't locked out. The claim is checked FIRST and short-circuits, so a
    // claim-bearing admin pays no userDoc() read. Once every admin carries the claim, drop the
    // role fallback (and the get() it costs). See docs/security/ADMIN-BOOTSTRAP.md.
    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.admin == true || userDoc().role == 'admin');
    }

    // True if the signed-in user owns or co-edits a page, given that page's data.
    function isOwnerOrEditor(data) {
      return isSignedIn() && (
        data.ownerId == request.auth.uid ||
        request.auth.uid in data.get('editorIds', [])
      );
    }

    // ── P1-b write-shape helpers (see docs/security/SECURITY-BASELINE.md §P1-b) ──
    // The set of keys a write actually changed. Only meaningful inside an UPDATE rule
    // (request.resource.data is the post-merge doc, resource.data is the stored doc); never
    // call it on create (resource is null there). The CREATE/UPDATE asymmetry is the load-bearing
    // rule of P1-b: on UPDATE the merged doc still carries every create-only/computed field a
    // partial write never sends, so keys().hasOnly() would reject 100% of legit updates — we must
    // constrain only the CHANGED keys instead. keys().hasOnly() is correct ONLY on create.
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // #4 (HIGH): ownerId and editorIds are live authz signals (isOwnerOrEditor reads both) but
    // were mutable on non-admin updates — an editor could rewrite ownerId to themselves, or
    // grant themselves editor, and take over the page. No legitimate client write path touches
    // either after create (only the Admin SDK / admin console does), so freezing them on the
    // non-admin arm closes the takeover with zero breakage. Admin writes bypass (isAdmin branch).
    function keepsOwner() {
      return request.resource.data.get('ownerId', null) == resource.data.get('ownerId', null);
    }
    function keepsEditors() {
      return !changedKeys().hasAny(['editorIds']);
    }

    // Data of a school doc by id (used by its private subcollection).
    function schoolData(id) {
      return get(/databases/$(database)/documents/schools/$(id)).data;
    }

    // Data of a business doc by id (used by subscriptions).
    function businessData(id) {
      return get(/databases/$(database)/documents/businesses/$(id)).data;
    }

    // Data of a subscription / contribution doc by id (used by their private subcollections,
    // which resolve who may see the donor's denormalized name).
    function subscriptionData(id) {
      return get(/databases/$(database)/documents/subscriptions/$(id)).data;
    }
    function contributionData(id) {
      return get(/databases/$(database)/documents/projectContributions/$(id)).data;
    }
    function raffleOrderData(id) {
      return get(/databases/$(database)/documents/raffleOrders/$(id)).data;
    }

    // ── users/{uid} ─────────────────────────────────────────────────────────
    // Each user can only read/write their own document. Admin can do everything. The `role`
    // field is the admin trust anchor (see isAdmin), so it is FROZEN to non-admins: a user
    // creates their own doc as 'user' and may never change `role` on their own doc. Only an
    // existing admin (isAdmin branch) — or the Admin SDK via the grant/revoke callables, which
    // also set the unforgeable custom claim — may change a role. Without this guard any
    // signed-in user could self-assign role:'admin' and own the whole platform.
    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn() && request.auth.uid == uid &&
        request.resource.data.role == 'user';
      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == uid &&
        request.resource.data.get('role', 'user') == resource.data.get('role', 'user')
      );
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // ── businesses/{id} ─────────────────────────────────────────────────────
    // Public read. Write: owner (ownerId), co-editors (editorIds) or admin. The ranking
    // and review aggregates are maintained by Cloud Functions (Admin SDK), so non-admin
    // updates must leave `ranking` and `reviewStats` untouched — owners can't self-promote.
    match /businesses/{id} {
      allow read: if true;
      allow create: if isAdmin() ||
        (isSignedIn() && request.resource.data.ownerId == request.auth.uid &&
          validBusinessCreate());
      allow update: if isAdmin() ||
        (isOwnerOrEditor(resource.data) && preservesComputedFields() &&
          validBusinessUpdate());
      allow delete: if isAdmin() || isOwnerOrEditor(resource.data);

      // Daily metric counters (doc id = YYYY-MM-DD): written ONLY by the
      // trackInteraction Cloud Function (Admin SDK bypasses these rules). They feed the
      // owner's private funnel report — not public data, never part of the ranking.
      match /metricsDaily/{day} {
        allow read: if isAdmin() || isOwnerOrEditor(businessData(id));
        allow write: if false;
      }

      // Reviews: businesses/{id}/reviews/{userId}, doc id = author uid (one per user).
      // Public read; write requires sign-in as that user, a 1–5 rating, a text capped
      // at 600 chars (the form enforces the same limit; the cap stops layout-breaking
      // walls of text on someone else's profile), and the author must NOT own/edit the
      // business (no self-reviews). Admin may delete (moderation).
      match /reviews/{userId} {
        allow read: if true;
        allow create, update: if isSignedIn() &&
          request.auth.uid == userId &&
          request.resource.data.rating is int &&
          request.resource.data.rating >= 1 &&
          request.resource.data.rating <= 5 &&
          request.resource.data.text is string &&
          request.resource.data.text.size() <= 600 &&
          !isOwnerOrEditor(businessData(id));
        allow delete: if isAdmin() ||
          (isSignedIn() && request.auth.uid == userId);
      }

      // Private subcollection (businesses/{id}/private/data): owner-only contact details kept
      // OFF the world-readable business doc — currently the contact email, which renders on no
      // public surface, so leaving it on the public doc made it a harvestable email in every
      // catalog scrape (#13). Owner/editors of THIS business or admin only; NEVER public (unlike
      // the business doc, which is world-readable). Unlike the schools private rule there is no
      // verification gate — a business has no verification lifecycle and no supporter-read path.
      match /private/{docId} {
        allow read, write: if isAdmin() || isOwnerOrEditor(businessData(id));
      }
    }

    // True if a business update leaves the function-maintained aggregates unchanged.
    function preservesComputedFields() {
      return request.resource.data.get('ranking', null) == resource.data.get('ranking', null) &&
        request.resource.data.get('reviewStats', null) == resource.data.get('reviewStats', null);
    }

    // P1-b write-shape validation for businesses (non-admin arm only). CREATE: the doc IS the
    // payload, so keys().hasOnly() pins the exact field set createBusinessPage writes (junk keys
    // rejected) and forces the draft/unverified start. UPDATE: constrains only the CHANGED keys
    // (gallery arrayUnion, setBusinessStatus and the profile edit each touch a different subset),
    // freezes ownerId/editorIds, and — by omitting slug/verified/ranking/reviewStats/metrics from
    // the allowed set — keeps them immutable. logoUrl/coverUrl/tags/hours are conditional, so they
    // are allowed but never required; description is type-only on update (legacy docs may exceed
    // 300 and the form re-saves them); photos uses a generous cap (arrayUnion on legacy >5 docs).
    function validBusinessCreate() {
      return request.resource.data.keys().hasOnly([
          'name', 'slug', 'description', 'categories', 'categoryNames', 'location', 'schoolId',
          'schoolName', 'contact', 'discount', 'logoUrl', 'coverUrl', 'photos', 'tags', 'status',
          'verified', 'subscription', 'ranking', 'metrics', 'reviewStats', 'ownerId', 'editorIds',
          'createdAt', 'updatedAt']) &&
        request.resource.data.status == 'draft' &&
        request.resource.data.verified == false &&
        request.resource.data.name is string &&
        request.resource.data.slug is string &&
        request.resource.data.description is string &&
        request.resource.data.description.size() <= 300 &&
        request.resource.data.categories is list &&
        request.resource.data.location is map &&
        request.resource.data.contact is map &&
        request.resource.data.discount is map &&
        request.resource.data.photos is list;
    }
    function validBusinessUpdate() {
      return keepsOwner() && keepsEditors() &&
        changedKeys().hasOnly([
          'name', 'description', 'categories', 'categoryNames', 'schoolId', 'schoolName',
          'location', 'contact', 'discount', 'tags', 'hours', 'logoUrl', 'coverUrl', 'status',
          'photos', 'updatedAt']) &&
        (!changedKeys().hasAny(['name']) || request.resource.data.name is string) &&
        (!changedKeys().hasAny(['description']) || request.resource.data.description is string) &&
        (!changedKeys().hasAny(['status']) ||
          request.resource.data.status in ['draft', 'active']) &&
        (!changedKeys().hasAny(['photos']) ||
          (request.resource.data.photos is list && request.resource.data.photos.size() <= 10)) &&
        (!changedKeys().hasAny(['tags']) ||
          (request.resource.data.tags is list && request.resource.data.tags.size() <= 15)) &&
        (!changedKeys().hasAny(['categories']) || request.resource.data.categories is list) &&
        (!changedKeys().hasAny(['location']) || request.resource.data.location is map) &&
        (!changedKeys().hasAny(['contact']) || request.resource.data.contact is map) &&
        (!changedKeys().hasAny(['discount']) || request.resource.data.discount is map);
    }

    // ── schools/{id} ────────────────────────────────────────────────────────
    // Public read of the doc. Self-administered with admin-gated verification:
    // - create: signed-in user as owner, forced unverified ('pending').
    // - update: owner/editors, but they may NEVER elevate verification (only admin can).
    match /schools/{id} {
      allow read: if true;

      allow create: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.verified == false &&
        request.resource.data.verificationStatus == 'pending' &&
        validSchoolCreate()
      );

      allow update: if isAdmin() || (
        isOwnerOrEditor(resource.data) &&
        !grantsVerification() &&
        renamePreservesVerification() &&
        validSchoolUpdate()
      );

      allow delete: if isAdmin() || isOwnerOrEditor(resource.data);

      // Private subcollection (payment methods):
      // - write: owner/editors of THIS school, or admin — but NOT while the school is
      //   currently 'verified'. To change payment methods on a verified school the owner must
      //   first drop it to needs_reverification (allowed on the school doc), which re-hides the
      //   methods behind the read-gate below until admin re-approves. Without this an owner
      //   could swap in their own account number on an approved school and it would stay
      //   publicly readable with no admin re-review (decision #6). Admin may always write.
      // - read: owner/editors or admin always; plus ANY signed-in user (e.g. a business
      //   wanting to subscribe) but ONLY when the school is 'verified'. Never anonymous.
      match /private/{docId} {
        allow write: if isAdmin() || (
          isOwnerOrEditor(schoolData(id)) &&
          schoolData(id).verificationStatus != 'verified'
        );
        allow read: if isAdmin() || isOwnerOrEditor(schoolData(id)) ||
          (isSignedIn() && schoolData(id).verificationStatus == 'verified');
      }

      // Projects (crowdfunding): schools/{id}/projects/{projectId}.
      // - read: public (the project section + detail page are SSR).
      // - create/update/delete: the school's owner/editors or admin.
      // `raised`/`contributorsCount` are derived from confirmed contributions by a Cloud
      // Function (Admin SDK bypasses these rules); a non-admin write must leave them at
      // zero (create) or unchanged (update) so the public progress bar can't be faked.
      match /projects/{projectId} {
        allow read: if true;
        allow create: if isAdmin() || (
          isOwnerOrEditor(schoolData(id)) &&
          request.resource.data.raised == 0 &&
          request.resource.data.contributorsCount == 0 &&
          validProjectCreate()
        );
        allow update: if isAdmin() || (
          isOwnerOrEditor(schoolData(id)) && preservesProjectCounters() &&
          validProjectUpdate()
        );
        allow delete: if isAdmin() || isOwnerOrEditor(schoolData(id));
      }

      // Tools ("Herramientas"): schools/{id}/tools/{toolId} — lightweight activities (rifa,
      // venta, bingo…) shown as cards on the public "Principal" tab.
      // - read: public (the section + detail page are SSR).
      // - create/update/delete: the school's owner/editors or admin.
      // Unlike projects there are NO function-maintained fields (no counters to freeze) — the
      // school owns every field — so the only guards are the write-shape validators, which pin
      // the field set, the type/status enums and the text caps. The optional CTA url scheme is
      // checked on the WRITE side (safeExternalUrl — rules can't parse URLs), so here it is only
      // shape/length-validated.
      match /tools/{toolId} {
        allow read: if true;
        allow create: if isAdmin() || (
          isOwnerOrEditor(schoolData(id)) && validToolCreate()
        );
        allow update: if isAdmin() || (
          isOwnerOrEditor(schoolData(id)) && validToolUpdate()
        );
        allow delete: if isAdmin() || isOwnerOrEditor(schoolData(id));
      }
    }

    // Collection-group reads of projects (`collectionGroup(db, 'projects')`). A nested
    // `match /schools/{id}/projects/...` rule governs direct + subcollection access but does
    // NOT authorize collection-group queries — those require a rule whose path reaches the
    // collection at ANY depth via a recursive wildcard. Read-only here (projects are public,
    // same as the nested rule); writes stay on the nested rule, which has the schoolId in
    // scope for the owner/counter checks. The /schools directory uses this to badge schools
    // with an active project in a single query.
    match /{path=**}/projects/{projectId} {
      allow read: if true;
    }

    // True if a project update leaves the function-maintained counters untouched.
    function preservesProjectCounters() {
      return request.resource.data.get('raised', 0) == resource.data.get('raised', 0) &&
        request.resource.data.get('contributorsCount', 0) ==
          resource.data.get('contributorsCount', 0);
    }

    // P1-b write-shape validation for projects (non-admin arm only). CREATE pins createProject's
    // field set, forces status 'active', and caps title/description/stage count (no per-stage deep
    // validation — rules can't iterate a list). UPDATE constrains the changed keys (updateProject
    // patch + setProjectStatus) and freezes ownerId; raised/contributorsCount stay frozen by
    // preservesProjectCounters() and out of the allowed set. Projects have no editorIds (authz is
    // via the parent school), so there is no keepsEditors() here.
    function validProjectCreate() {
      return request.resource.data.keys().hasOnly([
          'schoolId', 'schoolName', 'title', 'description', 'currency', 'status', 'stages',
          'raised', 'contributorsCount', 'ownerId', 'createdAt', 'updatedAt']) &&
        request.resource.data.status == 'active' &&
        request.resource.data.title is string &&
        request.resource.data.title.size() <= 120 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() <= 600 &&
        request.resource.data.currency in ['CRC', 'USD', 'NIO', 'MXN', 'EUR'] &&
        request.resource.data.stages is list &&
        request.resource.data.stages.size() <= 12 &&
        request.resource.data.ownerId is string;
    }
    function validProjectUpdate() {
      return keepsOwner() &&
        changedKeys().hasOnly([
          'title', 'description', 'currency', 'stages', 'coverUrl', 'status', 'updatedAt']) &&
        (!changedKeys().hasAny(['title']) ||
          (request.resource.data.title is string && request.resource.data.title.size() <= 120)) &&
        (!changedKeys().hasAny(['description']) ||
          (request.resource.data.description is string &&
            request.resource.data.description.size() <= 600)) &&
        (!changedKeys().hasAny(['currency']) ||
          request.resource.data.currency in ['CRC', 'USD', 'NIO', 'MXN', 'EUR']) &&
        (!changedKeys().hasAny(['status']) ||
          request.resource.data.status in ['active', 'completed', 'cancelled']) &&
        (!changedKeys().hasAny(['stages']) ||
          (request.resource.data.stages is list && request.resource.data.stages.size() <= 12));
    }

    // P1-b write-shape validation for tools (non-admin arm only). CREATE pins createTool's
    // field set (cover/dates/cta are added later via UPDATE, so they are NOT in the create
    // set) and validates the type/status enums + the text caps. UPDATE constrains the changed
    // keys (the edit form + setToolStatus) and freezes ownerId; the optional cta/startsAt/
    // endsAt/coverUrl are allowed but never required, so clearing them (deleteField) passes.
    // The cta shape is validated only when the key is PRESENT in the new doc (a delete removes
    // the key, so the guard is keyed on keys().hasAny, not changedKeys()).
    function validToolCreate() {
      return request.resource.data.keys().hasOnly([
          'schoolId', 'schoolName', 'type', 'title', 'description', 'status',
          'raffle', 'ownerId', 'createdAt', 'updatedAt']) &&
        request.resource.data.type in
          ['raffle', 'bingo', 'sale', 'service', 'guided_tour', 'other'] &&
        request.resource.data.status in ['active', 'inactive'] &&
        request.resource.data.title is string &&
        request.resource.data.title.size() <= 120 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() <= 600 &&
        request.resource.data.ownerId is string &&
        (!request.resource.data.keys().hasAny(['raffle']) ||
          request.resource.data.raffle is map);
    }
    function validToolUpdate() {
      return keepsOwner() &&
        changedKeys().hasOnly([
          'type', 'title', 'description', 'status', 'coverUrl', 'startsAt', 'endsAt',
          'cta', 'raffle', 'updatedAt']) &&
        (!changedKeys().hasAny(['type']) ||
          request.resource.data.type in
            ['raffle', 'bingo', 'sale', 'service', 'guided_tour', 'other']) &&
        (!changedKeys().hasAny(['status']) ||
          request.resource.data.status in ['active', 'inactive']) &&
        (!changedKeys().hasAny(['title']) ||
          (request.resource.data.title is string &&
            request.resource.data.title.size() <= 120)) &&
        (!changedKeys().hasAny(['description']) ||
          (request.resource.data.description is string &&
            request.resource.data.description.size() <= 600)) &&
        (!request.resource.data.keys().hasAny(['raffle']) ||
          request.resource.data.raffle is map) &&
        (!request.resource.data.keys().hasAny(['cta']) ||
          (request.resource.data.cta is map &&
            request.resource.data.cta.label is string &&
            request.resource.data.cta.label.size() <= 40 &&
            request.resource.data.cta.url is string));
    }

    // True if this update would elevate the school's verification state. Owners must
    // not be able to self-verify; only admin may grant 'verified'/verified:true.
    function grantsVerification() {
      return (request.resource.data.verified == true && resource.data.verified != true) ||
        (request.resource.data.verificationStatus == 'verified' &&
         resource.data.verificationStatus != 'verified');
    }

    // A verified school that renames must SIMULTANEOUSLY drop to needs_reverification: the
    // name is admin-reviewed sensitive metadata (decision #6) shown next to the verified badge,
    // so an owner cannot quietly change it while keeping the badge. True when the update is
    // allowed: the school isn't verified, or the name is unchanged, or the change also drops
    // verification. (Payment-method changes are gated separately on the private/ write rule.)
    function renamePreservesVerification() {
      return resource.data.verificationStatus != 'verified' ||
        request.resource.data.name == resource.data.name ||
        (request.resource.data.verificationStatus == 'needs_reverification' &&
         request.resource.data.verified == false);
    }

    // P1-b write-shape validation for schools (non-admin arm only). CREATE pins createSchoolPage's
    // field set and forces the pending start; it intentionally OMITS editorIds from the allowed
    // keys, so a non-admin can't seed co-editors at creation. UPDATE freezes ownerId/editorIds and
    // — by leaving status/metrics/createdAt out of the allowed set — keeps them immutable, while
    // still admitting every legit writer: the profile edit, the two gallery writers ({photos}),
    // and the re-verification downgrade ({verified:false, verificationStatus:'needs_reverification'}).
    // The verified:true / 'verified' GRANT stays admin-only via grantsVerification(). location/
    // name/boardContact shape is checked ONLY when actually changed, so a gallery add on a legacy
    // doc with an incomplete stored location is never re-validated.
    function validSchoolCreate() {
      return request.resource.data.keys().hasOnly([
          'name', 'description', 'thankYouMessage', 'location', 'boardContact', 'status',
          'verified', 'verificationStatus', 'metrics', 'ownerId', 'createdAt', 'updatedAt']) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.name is string &&
        request.resource.data.description is string &&
        request.resource.data.description.size() <= 300 &&
        request.resource.data.location is map &&
        request.resource.data.boardContact is map;
    }
    function validSchoolUpdate() {
      return keepsOwner() && keepsEditors() &&
        !changedKeys().hasAny(['status', 'metrics', 'createdAt']) &&
        changedKeys().hasOnly([
          'name', 'description', 'thankYouMessage', 'photoUrl', 'coverUrl', 'photos',
          'boardContact', 'location', 'verified', 'verificationStatus', 'updatedAt']) &&
        (!changedKeys().hasAny(['name']) || request.resource.data.name is string) &&
        (!changedKeys().hasAny(['description']) || request.resource.data.description is string) &&
        (!changedKeys().hasAny(['photos']) ||
          (request.resource.data.photos is list && request.resource.data.photos.size() <= 10)) &&
        (!changedKeys().hasAny(['boardContact']) || request.resource.data.boardContact is map) &&
        (!changedKeys().hasAny(['location']) || request.resource.data.location is map);
    }

    // ── categories/{id} ─────────────────────────────────────────────────────
    // Public read. Write: admin only.
    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── subscriptions/{id} ────────────────────────────────────────────────────
    // First-class support relationship: a supporter — a business page, or a signed-in
    // user donating personally (`supporterType: 'user'`) — supports a school.
    // - read: public. Confirmed support is public info (badge/ranking/thank-you wall,
    //   rendered SSR). The doc holds NO sensitive payment data — the payment proof file
    //   lives in Storage (subscription-proofs/{id}, gated by storage.rules); only
    //   `proofUploaded` is public.
    // - create: the supporter side (business owner/editor, or the donor themselves) or
    //   admin, forced to 'pending' — support can never start already confirmed.
    // - update: the supporter side may edit their own doc but may NEVER self-confirm,
    //   rewrite who supports whom, or grow `units`/`amount` once confirmed (ranking and
    //   donor tiers feed on those); only the TARGET school's owner/editors or admin may
    //   confirm/expire.
    // - delete: the supporter side or admin.
    match /subscriptions/{id} {
      allow read: if true;

      allow create: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.status == 'pending' &&
        request.resource.data.confirmedAt == null &&
        request.resource.data.get('firstConfirmedAt', null) == null &&
        request.resource.data.get('countsForRanking', false) == false &&
        // Business subs carry `units` on the public doc (the feed needs it). Personal
        // donations keep their magnitude (`units`/`amount`) in the private subdoc so a
        // scraper can't read how much a person gave — it is validated on the private create.
        (request.resource.data.get('supporterType', 'business') == 'user' ||
          (request.resource.data.units is int && request.resource.data.units >= 1)) &&
        isSupporterSide(request.resource.data) &&
        validSubscriptionCreate()
      );

      allow update: if isAdmin() || (
        keepsSupporterIdentity() && preservesRankingEligibility() &&
        validSubscriptionUpdate() && (
          isOwnerOrEditor(schoolData(resource.data.schoolId)) ||
          (isSupporterSide(resource.data) &&
            !changesConfirmation() &&
            keepsCommitmentOnceConfirmed())
        )
      );

      allow delete: if isAdmin() || isSupporterSide(resource.data);

      // Private: a personal donation's sensitive fields — the donor's real (proof-matching)
      // name AND its magnitude (`units`/`amount`) — denormalized OFF the public doc so an
      // anonymous scraper of `subscriptions` can neither deanonymize an opt-out donor nor read
      // how much they gave. Personal donations only — business subs keep `businessName`/`units`
      // public (the feed needs units), no private subdoc.
      // - read: the donor, the target school's owner/editors (to match the proof), or admin.
      // - create: the donor, while the parent is still `pending`; `units` validated here (the
      //   public create skips it for donor subs). - update: the donor, but once the school
      //   confirmed, `units`/`amount` are FROZEN — a post-confirm bump would inflate the donor
      //   tier (which the Cloud Function computes from THIS private `units`) with no new proof.
      function donorOwnsSub() {
        return isSignedIn() && subscriptionData(id).get('donorId', '') == request.auth.uid;
      }
      match /private/{doc} {
        allow read: if isAdmin() || donorOwnsSub() ||
          isOwnerOrEditor(schoolData(subscriptionData(id).schoolId));
        allow create: if isAdmin() || (
          donorOwnsSub() &&
          subscriptionData(id).status == 'pending' &&
          request.resource.data.units is int && request.resource.data.units >= 1
        );
        allow update: if isAdmin() || (
          donorOwnsSub() && (
            subscriptionData(id).status == 'pending' ||
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['units', 'amount'])
          )
        );
        allow delete: if isAdmin() || donorOwnsSub();
      }
    }

    // The supporter side of a subscription: owner/editor of the supporting business, or
    // the donating user themselves. Legacy docs lack `supporterType` → business-backed.
    // The type guard runs first (short-circuit) so business docs never dereference
    // `donorId` and donor docs never dereference `businessId` — an evaluation error
    // would deny the whole statement.
    function isSupporterSide(data) {
      return (
        data.get('supporterType', 'business') == 'business' &&
        isOwnerOrEditor(businessData(data.businessId))
      ) || (
        data.get('supporterType', 'business') == 'user' &&
        isSignedIn() &&
        data.get('donorId', '') == request.auth.uid
      );
    }

    // True if this update would alter the confirmation state. The supporter side must not
    // be able to self-confirm; only the school/admin may touch these fields.
    // `firstConfirmedAt` is included: it feeds the school's public response-time chip,
    // which the supporter must not be able to fake.
    function changesConfirmation() {
      return request.resource.data.status != resource.data.status ||
        request.resource.data.confirmedAt != resource.data.confirmedAt ||
        request.resource.data.expiresAt != resource.data.expiresAt ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['firstConfirmedAt']);
    }

    // No update may rewrite who supports whom: the structural identity is frozen at
    // create time (delete and re-create is the legitimate way to change it).
    function keepsSupporterIdentity() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(
        ['supporterType', 'businessId', 'donorId', 'schoolId']
      );
    }

    // The anti-fraud ranking eligibility flag is Cloud-Function-maintained (Admin SDK
    // bypasses these rules). No client write — neither the supporter nor the confirming
    // school — may touch it, or a self-dealer could re-enable their own excluded support.
    function preservesRankingEligibility() {
      return request.resource.data.get('countsForRanking', null) ==
        resource.data.get('countsForRanking', null);
    }

    // Once the school confirmed, the supporter may no longer change the committed
    // magnitude (a post-confirmation `units` bump would inflate ranking/tier without a
    // new proof). While 'pending' everything stays editable; re-uploading a proof for a
    // renewal only touches `proofUploaded`/`updatedAt`, which stays allowed.
    function keepsCommitmentOnceConfirmed() {
      return resource.data.status == 'pending' ||
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['units', 'amount']);
    }

    // P1-b write-shape validation for subscriptions (non-admin arm only). CREATE is PER-BRANCH on
    // supporterType: a business sub carries units/amount on the public doc (the feed needs them)
    // and amount must equal units × SUBSCRIPTION_UNIT_CRC (₡5.000, hardcoded — rules can't import
    // TS) with units capped at SUBSCRIPTION_UNITS_MAX (1000); a personal donation's branch OMITS
    // units/amount/businessId/donorName, so a donor doc that tries to expose its magnitude on the
    // public doc is rejected (defends P0-d — magnitude lives in private/data). UPDATE pins the
    // confirmation/proof fields only; countsForRanking is excluded (Cloud-Function-maintained, and
    // already frozen by preservesRankingEligibility()).
    function validSubscriptionCreate() {
      return (
        request.resource.data.get('supporterType', 'business') == 'business' &&
        request.resource.data.keys().hasOnly([
          'supporterType', 'businessId', 'businessName', 'schoolId', 'schoolName', 'units',
          'amount', 'status', 'confirmedAt', 'firstConfirmedAt', 'expiresAt', 'createdAt',
          'updatedAt']) &&
        request.resource.data.businessId is string &&
        request.resource.data.units is int &&
        request.resource.data.units >= 1 &&
        request.resource.data.units <= 1000 &&
        request.resource.data.amount == request.resource.data.units * 5000
      ) || (
        request.resource.data.supporterType == 'user' &&
        request.resource.data.keys().hasOnly([
          'supporterType', 'donorId', 'schoolId', 'schoolName', 'status', 'confirmedAt',
          'firstConfirmedAt', 'expiresAt', 'createdAt', 'updatedAt'])
      );
    }
    function validSubscriptionUpdate() {
      return changedKeys().hasOnly([
        'status', 'confirmedAt', 'confirmedBy', 'expiresAt', 'firstConfirmedAt',
        'proofUploaded', 'updatedAt']);
    }

    // ── projectContributions/{id} ─────────────────────────────────────────────
    // One-off contribution to a school project. Like subscriptions, the doc holds NO
    // sensitive payment data — the proof file lives in Storage
    // (project-contribution-proofs/{id}, gated by storage.rules); only `proofUploaded`
    // is public.
    // - read: public (confirmed contributions feed the public progress bar and counts).
    // - create: the contributor themselves, forced to 'pending', and ONLY while the
    //   target school is 'verified' — the same gate the SINPE data uses, so an unverified
    //   school can list projects but its "Financiar" button stays off.
    // - update: the contributor may edit their own pending doc (e.g. the proof flag) but
    //   may NEVER self-confirm or rewrite who/what; only the TARGET school's owner/editors
    //   or admin may confirm. The structural identity is frozen at create time.
    // - delete: the contributor or admin.
    match /projectContributions/{id} {
      allow read: if true;

      allow create: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.donorId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.confirmedAt == null &&
        schoolData(request.resource.data.schoolId).verificationStatus == 'verified' &&
        validContributionCreate()
      );

      allow update: if isAdmin() || (
        keepsContributionIdentity() && validContributionUpdate() &&
        confirmsContributionFromPending() && (
          isOwnerOrEditor(schoolData(resource.data.schoolId)) ||
          (isSignedIn() &&
            resource.data.donorId == request.auth.uid &&
            !changesContributionConfirmation())
        )
      );

      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.donorId == request.auth.uid);

      // Private: a contribution's sensitive fields — the contributor's real (proof-matching)
      // name AND its `amount` — denormalized OFF the public doc (same rationale as
      // subscriptions/private: anonymous scrapers can't deanonymize nor read how much a person
      // gave). The project's public `raised` bar is the Cloud-Function aggregate, which reads
      // THIS private `amount`.
      // - read: the contributor, the target school's owner/editors, or admin.
      // - create: the contributor, while the parent is still `pending`. - update: the
      //   contributor, but once the school confirmed, `amount` is FROZEN (a post-confirm bump
      //   would inflate `raised` with no new proof).
      function donorOwnsContribution() {
        return isSignedIn() && contributionData(id).donorId == request.auth.uid;
      }
      match /private/{doc} {
        allow read: if isAdmin() || donorOwnsContribution() ||
          isOwnerOrEditor(schoolData(contributionData(id).schoolId));
        allow create: if isAdmin() || (
          donorOwnsContribution() && contributionData(id).status == 'pending'
        );
        allow update: if isAdmin() || (
          donorOwnsContribution() && (
            contributionData(id).status == 'pending' ||
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['amount'])
          )
        );
        allow delete: if isAdmin() || donorOwnsContribution();
      }
    }

    // No update may rewrite who contributed what to which project (frozen at create).
    function keepsContributionIdentity() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(
        ['schoolId', 'projectId', 'donorId', 'type', 'amount', 'currency']
      );
    }

    // True if an update would alter the confirmation state — the contributor must not be
    // able to self-confirm; only the school/admin may touch these fields.
    function changesContributionConfirmation() {
      return request.resource.data.status != resource.data.status ||
        request.resource.data.confirmedAt != resource.data.confirmedAt;
    }

    // A contribution is confirmed exactly ONCE (pending → confirmed; no renewal, unlike a
    // subscription). A write that sets status to 'confirmed' is allowed only FROM a pending doc,
    // so the school can't RE-CONFIRM an already-confirmed contribution — a re-confirm would
    // re-stamp confirmedAt and make the Cloud Function append a DUPLICATE audit event under a
    // fresh trigger event id (which the function-side event.id dedup can't catch). Admin keeps the
    // correction capability (it bypasses this whole arm). Closes #11 for contributions. (P1-h)
    function confirmsContributionFromPending() {
      return request.resource.data.status != 'confirmed' ||
        resource.data.status == 'pending';
    }

    // P1-b write-shape validation for projectContributions (non-admin arm only). CREATE pins
    // createContribution's PUBLIC field set — it OMITS amount/donorName (those live in
    // private/data, P0-d), so a contributor can't expose their magnitude/name on the public doc —
    // and validates the type/currency enums, the title cap, and the optional in-kind fields
    // (guarded with get-defaults so a plain money contribution that omits them still passes).
    // UPDATE pins the confirmation/proof fields only.
    function validContributionCreate() {
      return request.resource.data.keys().hasOnly([
          'schoolId', 'schoolName', 'projectId', 'projectTitle', 'type', 'donorId', 'currency',
          'status', 'confirmedAt', 'createdAt', 'updatedAt', 'description', 'stageIndex',
          'stageTitle']) &&
        request.resource.data.type in ['money', 'in_kind'] &&
        request.resource.data.currency in ['CRC', 'USD', 'NIO', 'MXN', 'EUR'] &&
        request.resource.data.projectTitle is string &&
        request.resource.data.projectTitle.size() <= 120 &&
        request.resource.data.get('description', '') is string &&
        request.resource.data.get('description', '').size() <= 500 &&
        request.resource.data.get('stageTitle', '') is string &&
        request.resource.data.get('stageTitle', '').size() <= 120 &&
        request.resource.data.get('stageIndex', 0) is int &&
        request.resource.data.get('stageIndex', 0) >= 0 &&
        request.resource.data.get('stageIndex', 0) <= 11;
    }
    function validContributionUpdate() {
      return changedKeys().hasOnly([
        'status', 'confirmedAt', 'confirmedBy', 'proofUploaded', 'updatedAt']);
    }

    // ── raffleOrders/{id} ─────────────────────────────────────────────────────
    // A buyer's reservation of raffle numbers, awaiting the school's payment confirmation.
    // Top-level (like projectContributions) so its proof file + private subdoc resolve by id.
    // The doc holds NO sensitive data — the buyer's name + amount live in the private subdoc,
    // the proof file in Storage (raffle-order-proofs/{id}); only `proofUploaded` is public.
    // - read: public (the number grid derives reserved/sold from each order's numbers+status).
    // - create: the buyer themselves, forced 'pending', and ONLY while the target school is
    //   'verified' — same gate as contributions, so an unverified school can show a raffle but
    //   its "Comprar" can't complete.
    // - update: the buyer may edit their own pending doc (the proof flag) but may NEVER
    //   self-confirm or rewrite who/which numbers; only the TARGET school's owner/editors or
    //   admin may confirm. Identity (numbers included) frozen at create.
    // - delete: the buyer or admin.
    match /raffleOrders/{id} {
      allow read: if true;

      allow create: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.buyerId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.confirmedAt == null &&
        schoolData(request.resource.data.schoolId).verificationStatus == 'verified' &&
        validRaffleOrderCreate()
      );

      allow update: if isAdmin() || (
        keepsRaffleOrderIdentity() && validRaffleOrderUpdate() &&
        confirmsRaffleOrderFromPending() && (
          isOwnerOrEditor(schoolData(resource.data.schoolId)) ||
          (isSignedIn() &&
            resource.data.buyerId == request.auth.uid &&
            !changesRaffleOrderConfirmation())
        )
      );

      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.buyerId == request.auth.uid);

      // Private: the buyer's real (proof-matching) name AND the amount — denormalized OFF the
      // public doc so an anonymous scraper can't deanonymize nor read how much a person paid.
      // - read: the buyer, the target school's owner/editors, or admin.
      // - create: the buyer, while the parent is still 'pending'. - update: the buyer, but once
      //   the school confirmed, `amount` is FROZEN.
      function buyerOwnsOrder() {
        return isSignedIn() && raffleOrderData(id).buyerId == request.auth.uid;
      }
      match /private/{doc} {
        allow read: if isAdmin() || buyerOwnsOrder() ||
          isOwnerOrEditor(schoolData(raffleOrderData(id).schoolId));
        allow create: if isAdmin() || (
          buyerOwnsOrder() && raffleOrderData(id).status == 'pending'
        );
        allow update: if isAdmin() || (
          buyerOwnsOrder() && (
            raffleOrderData(id).status == 'pending' ||
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['amount'])
          )
        );
        allow delete: if isAdmin() || buyerOwnsOrder();
      }
    }

    // No update may rewrite who reserved which numbers in which raffle (frozen at create).
    function keepsRaffleOrderIdentity() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(
        ['schoolId', 'toolId', 'buyerId', 'numbers', 'currency']
      );
    }
    // The buyer must not self-confirm; only the school/admin may touch these fields.
    function changesRaffleOrderConfirmation() {
      return request.resource.data.status != resource.data.status ||
        request.resource.data.confirmedAt != resource.data.confirmedAt;
    }
    // Confirmed exactly once (pending → confirmed) so the school can't re-confirm (no renewal).
    function confirmsRaffleOrderFromPending() {
      return request.resource.data.status != 'confirmed' ||
        resource.data.status == 'pending';
    }
    // CREATE pins the PUBLIC field set — it OMITS buyerName/amount (those live in private/data),
    // validates the currency enum and the numbers list bounds. UPDATE pins the
    // confirmation/proof fields only.
    function validRaffleOrderCreate() {
      return request.resource.data.keys().hasOnly([
          'schoolId', 'schoolName', 'toolId', 'toolTitle', 'buyerId', 'numbers', 'currency',
          'status', 'confirmedAt', 'createdAt', 'updatedAt']) &&
        request.resource.data.currency in ['CRC', 'USD', 'NIO', 'MXN', 'EUR'] &&
        request.resource.data.toolTitle is string &&
        request.resource.data.toolTitle.size() <= 120 &&
        request.resource.data.numbers is list &&
        request.resource.data.numbers.size() >= 1 &&
        request.resource.data.numbers.size() <= 100;
    }
    function validRaffleOrderUpdate() {
      return changedKeys().hasOnly([
        'status', 'confirmedAt', 'confirmedBy', 'proofUploaded', 'updatedAt']);
    }

    // ── auditEvents/{id} ──────────────────────────────────────────────────────
    // Append-only, non-sensitive audit trail of confirmations (who/when + collusion
    // signals; never the proof or a money figure). Written ONLY by the Cloud Function
    // (Admin SDK bypasses these rules). Admin-only read — it backs fraud review and the
    // future risk-scoring feature store; no client may read or write it.
    match /auditEvents/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── adminEvents/{id} ──────────────────────────────────────────────────────
    // Append-only trail of privileged admin actions (role grants/revokes; extend with
    // verify/delete later) so the highest-authority actor is itself reviewable. Written ONLY
    // by the Admin SDK (the grant/revoke callables). Admin-only read; no client write.
    match /adminEvents/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── donorProfiles/{uid} ───────────────────────────────────────────────────
    // Public recognition surface for personal donors (doc id = uid). The donor owns the
    // recognition preferences (displayName, isPublic); totals and tier are derived from
    // CONFIRMED donations by a Cloud Function (Admin SDK bypasses these rules), so
    // clients can never self-assign a tier.
    // - read: the donor and admin always; everyone else only when the donor opted in
    //   (isPublic) — an opted-out donor still counts in aggregates but stays anonymous.
    // - create: the donor, with every computed field zeroed (no seeding fake totals).
    // - update: the donor may touch only the preference fields; admin freely.
    match /donorProfiles/{uid} {
      allow read: if isAdmin() ||
        (isSignedIn() && request.auth.uid == uid) ||
        resource.data.isPublic == true;

      allow create: if isSignedIn() && request.auth.uid == uid &&
        request.resource.data.keys().hasOnly([
          'displayName', 'isPublic', 'totalUnits', 'tier', 'schoolsSupported',
          'projectsSupported', 'firstConfirmedAt', 'lastConfirmedAt', 'createdAt', 'updatedAt']) &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() <= 60 &&
        request.resource.data.isPublic is bool &&
        request.resource.data.totalUnits == 0 &&
        request.resource.data.tier == null &&
        request.resource.data.schoolsSupported == 0 &&
        request.resource.data.get('projectsSupported', 0) == 0 &&
        request.resource.data.firstConfirmedAt == null &&
        request.resource.data.lastConfirmedAt == null;

      // P1-b: the donor may touch ONLY the two preference fields (displayName/isPublic).
      // hasOnly() both blocks junk keys and keeps every computed field (tier/totals) frozen —
      // it subsumes the previous explicit per-field freeze.
      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == uid &&
        changedKeys().hasOnly(['displayName', 'isPublic', 'updatedAt']) &&
        (!changedKeys().hasAny(['displayName']) ||
          (request.resource.data.displayName is string &&
            request.resource.data.displayName.size() <= 60)) &&
        (!changedKeys().hasAny(['isPublic']) || request.resource.data.isPublic is bool)
      );

      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }
  }
}
