rules_version = '2';

// Security rules for escuelaplace.com
//
// Principles:
// - Public catalog: businesses, schools and categories are READ without authentication (SEO/SSR).
// - The platform NEVER processes payments: there are no transaction collections.
// - Buyers ("person") have NO account: they are not referenced here.
// - Personal donors: any signed-in user (no page needed) may support a school
//   (`supporterType: 'user'` on subscriptions). Their public recognition lives in
//   donorProfiles, is opt-in, and its tier/totals are Cloud-Function-maintained.
// - "Pages" model (Facebook-style): a user account administers one or more pages
//   (businesses and/or schools). Access control lives on the page doc via ownerId/editorIds.
// - Schools are self-administered but verification is admin-gated: owners can never set
//   themselves to 'verified'; only admin writes `verified`/`verificationStatus`.
// - Sensitive data (payment methods) lives in a private subcollection: readable/writable by the
//   school's owner/editors and admin. Public visibility of the payment methods is decided by the
//   data layer based on verificationStatus, not here.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Admin is anchored on the unforgeable custom claim (request.auth.token.admin), set ONLY
    // by the Admin SDK (functions/src/admin.ts grant/revoke + the bootstrap script). The
    // Firestore users/{uid}.role field is a non-authoritative MIRROR for the admin UI; it is
    // honored here as a transitional fallback so admins provisioned before the custom-claim
    // migration aren't locked out. The claim is checked FIRST and short-circuits, so a
    // claim-bearing admin pays no userDoc() read. Once every admin carries the claim, drop the
    // role fallback (and the get() it costs). See docs/security/ADMIN-BOOTSTRAP.md.
    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.admin == true || userDoc().role == 'admin');
    }

    // True if the signed-in user owns or co-edits a page, given that page's data.
    function isOwnerOrEditor(data) {
      return isSignedIn() && (
        data.ownerId == request.auth.uid ||
        request.auth.uid in data.get('editorIds', [])
      );
    }

    // Data of a school doc by id (used by its private subcollection).
    function schoolData(id) {
      return get(/databases/$(database)/documents/schools/$(id)).data;
    }

    // Data of a business doc by id (used by subscriptions).
    function businessData(id) {
      return get(/databases/$(database)/documents/businesses/$(id)).data;
    }

    // Data of a subscription / contribution doc by id (used by their private subcollections,
    // which resolve who may see the donor's denormalized name).
    function subscriptionData(id) {
      return get(/databases/$(database)/documents/subscriptions/$(id)).data;
    }
    function contributionData(id) {
      return get(/databases/$(database)/documents/projectContributions/$(id)).data;
    }

    // ── users/{uid} ─────────────────────────────────────────────────────────
    // Each user can only read/write their own document. Admin can do everything. The `role`
    // field is the admin trust anchor (see isAdmin), so it is FROZEN to non-admins: a user
    // creates their own doc as 'user' and may never change `role` on their own doc. Only an
    // existing admin (isAdmin branch) — or the Admin SDK via the grant/revoke callables, which
    // also set the unforgeable custom claim — may change a role. Without this guard any
    // signed-in user could self-assign role:'admin' and own the whole platform.
    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn() && request.auth.uid == uid &&
        request.resource.data.role == 'user';
      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == uid &&
        request.resource.data.get('role', 'user') == resource.data.get('role', 'user')
      );
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // ── businesses/{id} ─────────────────────────────────────────────────────
    // Public read. Write: owner (ownerId), co-editors (editorIds) or admin. The ranking
    // and review aggregates are maintained by Cloud Functions (Admin SDK), so non-admin
    // updates must leave `ranking` and `reviewStats` untouched — owners can't self-promote.
    match /businesses/{id} {
      allow read: if true;
      allow create: if isAdmin() ||
        (isSignedIn() && request.resource.data.ownerId == request.auth.uid);
      allow update: if isAdmin() ||
        (isOwnerOrEditor(resource.data) && preservesComputedFields());
      allow delete: if isAdmin() || isOwnerOrEditor(resource.data);

      // Daily metric counters (doc id = YYYY-MM-DD): written ONLY by the
      // trackInteraction Cloud Function (Admin SDK bypasses these rules). They feed the
      // owner's private funnel report — not public data, never part of the ranking.
      match /metricsDaily/{day} {
        allow read: if isAdmin() || isOwnerOrEditor(businessData(id));
        allow write: if false;
      }

      // Reviews: businesses/{id}/reviews/{userId}, doc id = author uid (one per user).
      // Public read; write requires sign-in as that user, a 1–5 rating, a text capped
      // at 600 chars (the form enforces the same limit; the cap stops layout-breaking
      // walls of text on someone else's profile), and the author must NOT own/edit the
      // business (no self-reviews). Admin may delete (moderation).
      match /reviews/{userId} {
        allow read: if true;
        allow create, update: if isSignedIn() &&
          request.auth.uid == userId &&
          request.resource.data.rating is int &&
          request.resource.data.rating >= 1 &&
          request.resource.data.rating <= 5 &&
          request.resource.data.text is string &&
          request.resource.data.text.size() <= 600 &&
          !isOwnerOrEditor(businessData(id));
        allow delete: if isAdmin() ||
          (isSignedIn() && request.auth.uid == userId);
      }
    }

    // True if a business update leaves the function-maintained aggregates unchanged.
    function preservesComputedFields() {
      return request.resource.data.get('ranking', null) == resource.data.get('ranking', null) &&
        request.resource.data.get('reviewStats', null) == resource.data.get('reviewStats', null);
    }

    // ── schools/{id} ────────────────────────────────────────────────────────
    // Public read of the doc. Self-administered with admin-gated verification:
    // - create: signed-in user as owner, forced unverified ('pending').
    // - update: owner/editors, but they may NEVER elevate verification (only admin can).
    match /schools/{id} {
      allow read: if true;

      allow create: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.verified == false &&
        request.resource.data.verificationStatus == 'pending'
      );

      allow update: if isAdmin() || (
        isOwnerOrEditor(resource.data) &&
        !grantsVerification() &&
        renamePreservesVerification()
      );

      allow delete: if isAdmin() || isOwnerOrEditor(resource.data);

      // Private subcollection (payment methods):
      // - write: owner/editors of THIS school, or admin — but NOT while the school is
      //   currently 'verified'. To change payment methods on a verified school the owner must
      //   first drop it to needs_reverification (allowed on the school doc), which re-hides the
      //   methods behind the read-gate below until admin re-approves. Without this an owner
      //   could swap in their own account number on an approved school and it would stay
      //   publicly readable with no admin re-review (decision #6). Admin may always write.
      // - read: owner/editors or admin always; plus ANY signed-in user (e.g. a business
      //   wanting to subscribe) but ONLY when the school is 'verified'. Never anonymous.
      match /private/{docId} {
        allow write: if isAdmin() || (
          isOwnerOrEditor(schoolData(id)) &&
          schoolData(id).verificationStatus != 'verified'
        );
        allow read: if isAdmin() || isOwnerOrEditor(schoolData(id)) ||
          (isSignedIn() && schoolData(id).verificationStatus == 'verified');
      }

      // Projects (crowdfunding): schools/{id}/projects/{projectId}.
      // - read: public (the project section + detail page are SSR).
      // - create/update/delete: the school's owner/editors or admin.
      // `raised`/`contributorsCount` are derived from confirmed contributions by a Cloud
      // Function (Admin SDK bypasses these rules); a non-admin write must leave them at
      // zero (create) or unchanged (update) so the public progress bar can't be faked.
      match /projects/{projectId} {
        allow read: if true;
        allow create: if isAdmin() || (
          isOwnerOrEditor(schoolData(id)) &&
          request.resource.data.raised == 0 &&
          request.resource.data.contributorsCount == 0
        );
        allow update: if isAdmin() || (
          isOwnerOrEditor(schoolData(id)) && preservesProjectCounters()
        );
        allow delete: if isAdmin() || isOwnerOrEditor(schoolData(id));
      }
    }

    // Collection-group reads of projects (`collectionGroup(db, 'projects')`). A nested
    // `match /schools/{id}/projects/...` rule governs direct + subcollection access but does
    // NOT authorize collection-group queries — those require a rule whose path reaches the
    // collection at ANY depth via a recursive wildcard. Read-only here (projects are public,
    // same as the nested rule); writes stay on the nested rule, which has the schoolId in
    // scope for the owner/counter checks. The /schools directory uses this to badge schools
    // with an active project in a single query.
    match /{path=**}/projects/{projectId} {
      allow read: if true;
    }

    // True if a project update leaves the function-maintained counters untouched.
    function preservesProjectCounters() {
      return request.resource.data.get('raised', 0) == resource.data.get('raised', 0) &&
        request.resource.data.get('contributorsCount', 0) ==
          resource.data.get('contributorsCount', 0);
    }

    // True if this update would elevate the school's verification state. Owners must
    // not be able to self-verify; only admin may grant 'verified'/verified:true.
    function grantsVerification() {
      return (request.resource.data.verified == true && resource.data.verified != true) ||
        (request.resource.data.verificationStatus == 'verified' &&
         resource.data.verificationStatus != 'verified');
    }

    // A verified school that renames must SIMULTANEOUSLY drop to needs_reverification: the
    // name is admin-reviewed sensitive metadata (decision #6) shown next to the verified badge,
    // so an owner cannot quietly change it while keeping the badge. True when the update is
    // allowed: the school isn't verified, or the name is unchanged, or the change also drops
    // verification. (Payment-method changes are gated separately on the private/ write rule.)
    function renamePreservesVerification() {
      return resource.data.verificationStatus != 'verified' ||
        request.resource.data.name == resource.data.name ||
        (request.resource.data.verificationStatus == 'needs_reverification' &&
         request.resource.data.verified == false);
    }

    // ── categories/{id} ─────────────────────────────────────────────────────
    // Public read. Write: admin only.
    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── subscriptions/{id} ────────────────────────────────────────────────────
    // First-class support relationship: a supporter — a business page, or a signed-in
    // user donating personally (`supporterType: 'user'`) — supports a school.
    // - read: public. Confirmed support is public info (badge/ranking/thank-you wall,
    //   rendered SSR). The doc holds NO sensitive payment data — the payment proof file
    //   lives in Storage (subscription-proofs/{id}, gated by storage.rules); only
    //   `proofUploaded` is public.
    // - create: the supporter side (business owner/editor, or the donor themselves) or
    //   admin, forced to 'pending' — support can never start already confirmed.
    // - update: the supporter side may edit their own doc but may NEVER self-confirm,
    //   rewrite who supports whom, or grow `units`/`amount` once confirmed (ranking and
    //   donor tiers feed on those); only the TARGET school's owner/editors or admin may
    //   confirm/expire.
    // - delete: the supporter side or admin.
    match /subscriptions/{id} {
      allow read: if true;

      allow create: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.status == 'pending' &&
        request.resource.data.confirmedAt == null &&
        request.resource.data.get('firstConfirmedAt', null) == null &&
        request.resource.data.get('countsForRanking', false) == false &&
        // Business subs carry `units` on the public doc (the feed needs it). Personal
        // donations keep their magnitude (`units`/`amount`) in the private subdoc so a
        // scraper can't read how much a person gave — it is validated on the private create.
        (request.resource.data.get('supporterType', 'business') == 'user' ||
          (request.resource.data.units is int && request.resource.data.units >= 1)) &&
        isSupporterSide(request.resource.data)
      );

      allow update: if isAdmin() || (
        keepsSupporterIdentity() && preservesRankingEligibility() && (
          isOwnerOrEditor(schoolData(resource.data.schoolId)) ||
          (isSupporterSide(resource.data) &&
            !changesConfirmation() &&
            keepsCommitmentOnceConfirmed())
        )
      );

      allow delete: if isAdmin() || isSupporterSide(resource.data);

      // Private: a personal donation's sensitive fields — the donor's real (proof-matching)
      // name AND its magnitude (`units`/`amount`) — denormalized OFF the public doc so an
      // anonymous scraper of `subscriptions` can neither deanonymize an opt-out donor nor read
      // how much they gave. Personal donations only — business subs keep `businessName`/`units`
      // public (the feed needs units), no private subdoc.
      // - read: the donor, the target school's owner/editors (to match the proof), or admin.
      // - create: the donor, while the parent is still `pending`; `units` validated here (the
      //   public create skips it for donor subs). - update: the donor, but once the school
      //   confirmed, `units`/`amount` are FROZEN — a post-confirm bump would inflate the donor
      //   tier (which the Cloud Function computes from THIS private `units`) with no new proof.
      function donorOwnsSub() {
        return isSignedIn() && subscriptionData(id).get('donorId', '') == request.auth.uid;
      }
      match /private/{doc} {
        allow read: if isAdmin() || donorOwnsSub() ||
          isOwnerOrEditor(schoolData(subscriptionData(id).schoolId));
        allow create: if isAdmin() || (
          donorOwnsSub() &&
          subscriptionData(id).status == 'pending' &&
          request.resource.data.units is int && request.resource.data.units >= 1
        );
        allow update: if isAdmin() || (
          donorOwnsSub() && (
            subscriptionData(id).status == 'pending' ||
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['units', 'amount'])
          )
        );
        allow delete: if isAdmin() || donorOwnsSub();
      }
    }

    // The supporter side of a subscription: owner/editor of the supporting business, or
    // the donating user themselves. Legacy docs lack `supporterType` → business-backed.
    // The type guard runs first (short-circuit) so business docs never dereference
    // `donorId` and donor docs never dereference `businessId` — an evaluation error
    // would deny the whole statement.
    function isSupporterSide(data) {
      return (
        data.get('supporterType', 'business') == 'business' &&
        isOwnerOrEditor(businessData(data.businessId))
      ) || (
        data.get('supporterType', 'business') == 'user' &&
        isSignedIn() &&
        data.get('donorId', '') == request.auth.uid
      );
    }

    // True if this update would alter the confirmation state. The supporter side must not
    // be able to self-confirm; only the school/admin may touch these fields.
    // `firstConfirmedAt` is included: it feeds the school's public response-time chip,
    // which the supporter must not be able to fake.
    function changesConfirmation() {
      return request.resource.data.status != resource.data.status ||
        request.resource.data.confirmedAt != resource.data.confirmedAt ||
        request.resource.data.expiresAt != resource.data.expiresAt ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['firstConfirmedAt']);
    }

    // No update may rewrite who supports whom: the structural identity is frozen at
    // create time (delete and re-create is the legitimate way to change it).
    function keepsSupporterIdentity() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(
        ['supporterType', 'businessId', 'donorId', 'schoolId']
      );
    }

    // The anti-fraud ranking eligibility flag is Cloud-Function-maintained (Admin SDK
    // bypasses these rules). No client write — neither the supporter nor the confirming
    // school — may touch it, or a self-dealer could re-enable their own excluded support.
    function preservesRankingEligibility() {
      return request.resource.data.get('countsForRanking', null) ==
        resource.data.get('countsForRanking', null);
    }

    // Once the school confirmed, the supporter may no longer change the committed
    // magnitude (a post-confirmation `units` bump would inflate ranking/tier without a
    // new proof). While 'pending' everything stays editable; re-uploading a proof for a
    // renewal only touches `proofUploaded`/`updatedAt`, which stays allowed.
    function keepsCommitmentOnceConfirmed() {
      return resource.data.status == 'pending' ||
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['units', 'amount']);
    }

    // ── projectContributions/{id} ─────────────────────────────────────────────
    // One-off contribution to a school project. Like subscriptions, the doc holds NO
    // sensitive payment data — the proof file lives in Storage
    // (project-contribution-proofs/{id}, gated by storage.rules); only `proofUploaded`
    // is public.
    // - read: public (confirmed contributions feed the public progress bar and counts).
    // - create: the contributor themselves, forced to 'pending', and ONLY while the
    //   target school is 'verified' — the same gate the SINPE data uses, so an unverified
    //   school can list projects but its "Financiar" button stays off.
    // - update: the contributor may edit their own pending doc (e.g. the proof flag) but
    //   may NEVER self-confirm or rewrite who/what; only the TARGET school's owner/editors
    //   or admin may confirm. The structural identity is frozen at create time.
    // - delete: the contributor or admin.
    match /projectContributions/{id} {
      allow read: if true;

      allow create: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.donorId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.confirmedAt == null &&
        schoolData(request.resource.data.schoolId).verificationStatus == 'verified'
      );

      allow update: if isAdmin() || (
        keepsContributionIdentity() && (
          isOwnerOrEditor(schoolData(resource.data.schoolId)) ||
          (isSignedIn() &&
            resource.data.donorId == request.auth.uid &&
            !changesContributionConfirmation())
        )
      );

      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.donorId == request.auth.uid);

      // Private: a contribution's sensitive fields — the contributor's real (proof-matching)
      // name AND its `amount` — denormalized OFF the public doc (same rationale as
      // subscriptions/private: anonymous scrapers can't deanonymize nor read how much a person
      // gave). The project's public `raised` bar is the Cloud-Function aggregate, which reads
      // THIS private `amount`.
      // - read: the contributor, the target school's owner/editors, or admin.
      // - create: the contributor, while the parent is still `pending`. - update: the
      //   contributor, but once the school confirmed, `amount` is FROZEN (a post-confirm bump
      //   would inflate `raised` with no new proof).
      function donorOwnsContribution() {
        return isSignedIn() && contributionData(id).donorId == request.auth.uid;
      }
      match /private/{doc} {
        allow read: if isAdmin() || donorOwnsContribution() ||
          isOwnerOrEditor(schoolData(contributionData(id).schoolId));
        allow create: if isAdmin() || (
          donorOwnsContribution() && contributionData(id).status == 'pending'
        );
        allow update: if isAdmin() || (
          donorOwnsContribution() && (
            contributionData(id).status == 'pending' ||
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['amount'])
          )
        );
        allow delete: if isAdmin() || donorOwnsContribution();
      }
    }

    // No update may rewrite who contributed what to which project (frozen at create).
    function keepsContributionIdentity() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(
        ['schoolId', 'projectId', 'donorId', 'type', 'amount', 'currency']
      );
    }

    // True if an update would alter the confirmation state — the contributor must not be
    // able to self-confirm; only the school/admin may touch these fields.
    function changesContributionConfirmation() {
      return request.resource.data.status != resource.data.status ||
        request.resource.data.confirmedAt != resource.data.confirmedAt;
    }

    // ── auditEvents/{id} ──────────────────────────────────────────────────────
    // Append-only, non-sensitive audit trail of confirmations (who/when + collusion
    // signals; never the proof or a money figure). Written ONLY by the Cloud Function
    // (Admin SDK bypasses these rules). Admin-only read — it backs fraud review and the
    // future risk-scoring feature store; no client may read or write it.
    match /auditEvents/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── adminEvents/{id} ──────────────────────────────────────────────────────
    // Append-only trail of privileged admin actions (role grants/revokes; extend with
    // verify/delete later) so the highest-authority actor is itself reviewable. Written ONLY
    // by the Admin SDK (the grant/revoke callables). Admin-only read; no client write.
    match /adminEvents/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── donorProfiles/{uid} ───────────────────────────────────────────────────
    // Public recognition surface for personal donors (doc id = uid). The donor owns the
    // recognition preferences (displayName, isPublic); totals and tier are derived from
    // CONFIRMED donations by a Cloud Function (Admin SDK bypasses these rules), so
    // clients can never self-assign a tier.
    // - read: the donor and admin always; everyone else only when the donor opted in
    //   (isPublic) — an opted-out donor still counts in aggregates but stays anonymous.
    // - create: the donor, with every computed field zeroed (no seeding fake totals).
    // - update: the donor may touch only the preference fields; admin freely.
    match /donorProfiles/{uid} {
      allow read: if isAdmin() ||
        (isSignedIn() && request.auth.uid == uid) ||
        resource.data.isPublic == true;

      allow create: if isSignedIn() && request.auth.uid == uid &&
        request.resource.data.totalUnits == 0 &&
        request.resource.data.tier == null &&
        request.resource.data.schoolsSupported == 0 &&
        request.resource.data.get('projectsSupported', 0) == 0 &&
        request.resource.data.firstConfirmedAt == null &&
        request.resource.data.lastConfirmedAt == null;

      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(
          ['totalUnits', 'tier', 'schoolsSupported', 'projectsSupported',
           'firstConfirmedAt', 'lastConfirmedAt']
        )
      );

      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }
  }
}
