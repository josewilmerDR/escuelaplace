# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# firebase emulators
.emulator-data/
firebase-debug.log*
firestore-debug.log*
ui-debug.log*
*-debug.log

# vercel
.vercel

# claude code (personal settings only; .claude/settings.json is shared/committed)
.claude/settings.local.json
# claude code agent worktrees (scratch dirs for parallel agents)
.claude/worktrees/

# typescript
*.tsbuildinfo
next-env.d.ts
